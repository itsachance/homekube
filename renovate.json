{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "kubernetes": {
        "managerFilePatterns": [
            "/\\.yaml$/",
            "/\\.yml$/"
        ]
    },
    "flux": {
        "managerFilePatterns": [
            "/\\.yaml$/",
            "/\\.yml$/"
        ]
    },
    "helm-values": {
        "managerFilePatterns": [
            "/values\\.yaml$/",
            "/values\\.yml$/"
        ]
    },
    "kustomize": {
        "managerFilePatterns": [
            "/kustomization\\.yaml$/",
            "/kustomization\\.yml$/"
        ]
    }
}
